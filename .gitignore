daemon.lock

# In-tree local home, if ever created
/.acp-hub

# Editor / OS cruft
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db

# Local cargo credentials must never be committed
.cargo/credentials
.cargo/credentials.toml
