{
  "acpAgents": {
    "grok": {
      "transport": {
        "type": "stdio",
        "command": "node",
        "args": ["<absolute-path-to-acp-hub>/adapters/grok/adapter.mjs"],
        "env": {}
      },
      "permission_policy": "auto-allow",
      "client_capabilities": {
        "fs": {
          "read_text_file": true,
          "write_text_file": true,
          "allowed_roots": []
        },
        "terminal": true
      }
    }
  }
}
