{
  "acpAgents": {
    "cursor": {
      "transport": {
        "type": "stdio",
        "command": "cmd",
        "args": ["/c", "cursor-agent", "acp"],
        "env": {}
      },
      "permission_policy": "reject",
      "client_capabilities": {
        "fs": {
          "read_text_file": false,
          "write_text_file": false,
          "allowed_roots": []
        },
        "terminal": false
      }
    }
  }
}
