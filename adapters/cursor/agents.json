{
  "acpAgents": {
    "cursor": {
      "transport": {
        "type": "stdio",
        "command": "node",
        "args": ["<absolute-path-to-acp-hub>/adapters/cursor/adapter.mjs"],
        "env": {}
      },
      "permission_policy": "reject",
      "client_capabilities": {
        "fs": {
          "read_text_file": false,
          "write_text_file": false,
          "allowed_roots": []
        },
        "terminal": false
      }
    }
  }
}
