{
  "acpAgents": {
    "omp": {
      "transport": {
        "type": "stdio",
        "command": "omp",
        "args": ["acp"],
        "env": {}
      },
      "permission_policy": "auto-allow",
      "client_capabilities": {
        "fs": {
          "read_text_file": true,
          "write_text_file": true,
          "allowed_roots": []
        },
        "terminal": true
      }
    }
  }
}
