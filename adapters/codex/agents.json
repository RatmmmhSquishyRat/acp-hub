{
  "acpAgents": {
    "codex": {
      "transport": {
        "type": "stdio",
        "command": "node",
        "args": [
          "<absolute-path-to-codex-acp>/dist/index.js"
        ],
        "env": {}
      },
      "proxy_chain": [],
      "permission_policy": "auto-allow",
      "client_capabilities": {
        "fs": {
          "read_text_file": true,
          "write_text_file": true,
          "allowed_roots": []
        },
        "terminal": true
      }
    }
  },
  "acpProxies": {}
}
